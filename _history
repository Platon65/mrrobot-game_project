Math.PI / 180)\n\n# ===================== Globals =====================\nhero = None\necorp_guard = None\nterminal_node = None\n\nhack_bar_bg = None\nhack_bar_fill = None\ncrt_overlay = None\nborder_overlay = None\n\nguard_patrol_a_x = 34\nguard_patrol_a_y = 28\nguard_patrol_b_x = 132\nguard_patrol_b_y = 92\nguard_target_a = False\n\nguard_facing_x = 1\nguard_facing_y = 0\n\nis_hacking = False\nhack_progress_ms = 0\nterminal_hacked = False\ncaught = False\n\n# ===================== Helpers =====================\ndef dist(x1, y1, x2, y2):\n    dx = x2 - x1\n    dy = y2 - y1\n    return Math.sqrt(dx * dx + dy * dy)\n\ndef setup_background():\n    global border_overlay\n    scene.set_background_color(15)\n\n    border_img = image.create(screen.width, screen.height)\n    border_img.fill(0)\n\n    x = 0\n    while x < screen.width:\n        border_img.set_pixel(x, 4, 7)\n        border_img.set_pixel(x, screen.height - 5, 7)\n        x += 8\n\n    y = 0\n    while y < screen.height:\n        border_img.set_pixel(4, y, 7)\n        border_img.set_pixel(screen.width - 5, y, 7)\n        y += 8\n\n    border_overlay = sprites.create(border_img, SpriteKind.UI)\n    border_overlay.set_flag(SpriteFlag.Ghost, True)\n    border_overlay.set_flag(SpriteFlag.RelativeToCamera, True)\n    border_overlay.z = 80\n\ndef setup_ui():\n    global hack_bar_bg, hack_bar_fill\n\n    hack_bar_bg = sprites.create(image.create(50, 8), SpriteKind.UI)\n    hack_bar_bg.set_flag(SpriteFlag.Ghost, True)\n    hack_bar_bg.set_flag(SpriteFlag.RelativeToCamera, True)\n    hack_bar_bg.set_flag(SpriteFlag.Invisible, True)\n    hack_bar_bg.set_position(screen.width / 2, screen.height - 10)\n    hack_bar_bg.z = 90\n\n    hack_bar_fill = sprites.create(image.create(1, 4), SpriteKind.UI)\n    hack_bar_fill.set_flag(SpriteFlag.Ghost, True)\n    hack_bar_fill.set_flag(SpriteFlag.RelativeToCamera, True)\n    hack_bar_fill.set_flag(SpriteFlag.Invisible, True)\n    hack_bar_fill.z = 91\n\n    update_hack_bar(0)\n\ndef update_hack_bar(progress01):\n    bg_image = image.create(50, 8)\n    bg_image.fill(1)\n    bg_image.draw_rect(0, 0, 50, 8, 7)\n    hack_bar_bg.set_image(bg_image)\n\n    fill_w = Math.round(progress01 * 46)\n    if fill_w < 1:\n        fill_w = 1\n    if fill_w > 46:\n        fill_w = 46\n\n    fill_image = image.create(fill_w, 4)\n    fill_image.fill(7)\n    hack_bar_fill.set_image(fill_image)\n\n    hack_bar_fill.left = hack_bar_bg.left + 2\n    hack_bar_fill.y = hack_bar_bg.y\n\ndef set_hacking_state(active):\n    global is_hacking, hack_progress_ms\n    is_hacking = active\n\n    if active:\n        controller.move_sprite(hero, 0, 0)\n        hero.vx = 0\n        hero.vy = 0\n        hack_progress_ms = 0\n        update_hack_bar(0)\n        hack_bar_bg.set_flag(SpriteFlag.Invisible, False)\n        hack_bar_fill.set_flag(SpriteFlag.Invisible, False)\n    else:\n        controller.move_sprite(hero, PLAYER_SPEED, PLAYER_SPEED)\n        hack_bar_bg.set_flag(SpriteFlag.Invisible, True)\n        hack_bar_fill.set_flag(SpriteFlag.Invisible, True)\n\ndef move_guard_patrol():\n    global guard_target_a, guard_facing_x, guard_facing_y\n\n    if guard_target_a:\n        tx = guard_patrol_a_x\n        ty = guard_patrol_a_y\n    else:\n        tx = guard_patrol_b_x\n        ty = guard_patrol_b_y\n\n    dx = tx - ecorp_guard.x\n    dy = ty - ecorp_guard.y\n    length = Math.sqrt(dx * dx + dy * dy)\n\n    nx = 0\n    ny = 0\n    if length > 0.0001:\n        nx = dx / length\n        ny = dy / length\n\n    step = GUARD_SPEED / 60\n    ecorp_guard.x += nx * step\n    ecorp_guard.y += ny * step\n\n    if Math.abs(nx) > 0.001 or Math.abs(ny) > 0.001:\n        guard_facing_x = nx\n        guard_facing_y = ny\n\n    if dist(ecorp_guard.x, ecorp_guard.y, tx, ty) < 2:\n        guard_target_a = not guard_target_a\n\ndef guard_can_see_hero():\n    to_px = hero.x - ecorp_guard.x\n    to_py = hero.y - ecorp_guard.y\n    d = Math.sqrt(to_px * to_px + to_py * to_py)\n\n    if d > FOV_DISTANCE:\n        return False\n    if d < 0.0001:\n        return True\n\n    dir_to_hero_x = to_px / d\n    dir_to_hero_y = to_py / d\n    dot = guard_facing_x * dir_to_hero_x + guard_facing_y * dir_to_hero_y\n    return dot >= HALF_FOV_COS\n\ndef redraw_crt():\n    overlay_image = image.create(screen.width, screen.height)\n    overlay_image.fill(0)\n\n    y = 0\n    while y < screen.height:\n        overlay_image.draw_line(0, y, screen.width - 1, y, 1)\n        y += 2\n\n    i = 0\n    while i < 45:\n        overlay_image.set_pixel(randint(0, screen.width - 1), randint(0, screen.height - 1), 7)\n        i += 1\n\n    crt_overlay.set_image(overlay_image)\n\n# ===================== Init =====================\nsetup_background()\n\nhero = sprites.create(img(\"\"\"\n    . . 7 7 7 7 . .\n    . 7 7 7 7 7 7 .\n    7 7 5 7 7 5 7 7\n    7 7 7 7 7 7 7 7\n    7 7 7 7 7 7 7 7\n    . 7 7 7 7 7 7 .\n    . . 7 7 7 7 . .\n    . . . 7 7 . . .\n\"\"\"), SpriteKind.player)\nhero.set_position(22, 60)\nhero.set_stay_in_screen(True)\ncontroller.move_sprite(hero, PLAYER_SPEED, PLAYER_SPEED)\n\nterminal_node = sprites.create(img(\"\"\"\n    7 7 7 7 7 7 7 7\n    7 1 1 1 1 1 1 7\n    7 1 7 7 7 7 1 7\n    7 1 7 1 1 7 1 7\n    7 1 7 7 7 7 1 7\n    7 1 1 1 1 1 1 7\n    7 7 7 7 7 7 7 7\n    . . 7 7 7 7 . .\n\"\"\"), SpriteKind.Terminal)\nterminal_node.set_position(84, 60)\n\necorp_guard = sprites.create(img(\"\"\"\n    . 3 3 3 3 3 3 .\n    3 3 3 3 3 3 3 3\n    3 3 8 3 3 8 3 3\n    3 3 3 3 3 3 3 3\n    3 3 3 3 3 3 3 3\n    . 3 3 3 3 3 3 .\n    . . 3 3 3 3 . .\n    . . . 3 3 . . .\n\"\"\"), SpriteKind.Guard)\necorp_guard.set_position(guard_patrol_a_x, guard_patrol_a_y)\n\nsetup_ui()\n\ncrt_overlay = sprites.create(image.create(screen.width, screen.height), SpriteKind.UI)\ncrt_overlay.set_flag(SpriteFlag.Ghost, True)\ncrt_overlay.set_flag(SpriteFlag.RelativeToCamera, True)\ncrt_overlay.z = 100\nredraw_crt()\n\n# ===================== Loop =====================\ndef on_update():\n    global caught\n\n    if caught:\n        return\n\n    if not is_hacking:\n        move_guard_patrol()\n\n    if (not terminal_hacked) and (not is_hacking):\n        if dist(hero.x, hero.y, terminal_node.x, terminal_node.y) <= INTERACT_DISTANCE:\n            set_hacking_state(True)\n\n    if guard_can_see_hero():\n        caught = True\n        game.over(False, effects.melt)\n\ngame.on_update(on_update)\n\ndef on_update_hacking():\n    global hack_progress_ms, terminal_hacked\n\n    if caught:\n        return\n\n    if is_hacking:\n        hack_progress_ms += 100\n        p = hack_progress_ms / HACK_TIME_MS\n        if p > 1:\n            p = 1\n        update_hack_bar(p)\n\n        if hack_progress_ms >= HACK_TIME_MS:\n            terminal_hacked = True\n            terminal_node.set_image(img(\"\"\"\n                7 7 7 7 7 7 7 7\n                7 7 7 7 7 7 7 7\n                7 7 1 1 1 1 7 7\n                7 7 1 7 7 1 7 7\n                7 7 1 1 1 1 7 7\n                7 7 7 7 7 7 7 7\n                7 7 7 7 7 7 7 7\n                . . 7 7 7 7 . .\n            \"\"\"))\n            set_hacking_state(False)\n            game.splash(\"Hack complete\")\n\ngame.on_update_interval(100, on_update_hacking)\n\ndef on_update_crt():\n    redraw_crt()\n\ngame.on_update_interval(120, on_update_crt)\n","pxt.json":"{\n    \"name\": \"mr.robot game_project\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\"\n}\n"}}],"shares":[],"lastSaveTime":1773956878014}