{"entries":[{"timestamp":1773954346696,"editorVersion":"4.0.12","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":131,"diffs":[[1,"<xml xmlns=\"http://www.w3.org/1999/xhtml\">\n  <variables></variables>\n  <block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block>\n</xml>"]]}]},{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":1,"diffs":[[1," "]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":191,"length1":41,"diffs":[[1,"        \"assets.json\"\n"]]},{"start1":220,"length1":31,"diffs":[[1,"    \"additionalFilePaths\": []\n"]]}]},{"type":"added","filename":"main.py","value":"\nlet caught = false\n\n// UI: прогресс-бар\nlet hackBarBg: Sprite = null\nlet hackBarFill: Sprite = null\n\n// CRT overlay\nlet crtOverlay: Sprite = null\n\n// -------------------- Вспомогательные функции --------------------\nfunction distance(x1: number, y1: number, x2: number, y2: number): number {\n    let dx = x2 - x1\n    let dy = y2 - y1\n    return Math.sqrt(dx * dx + dy * dy)\n}\n\nfunction normalize(x: number, y: number): number[] {\n    let len = Math.sqrt(x * x + y * y)\n    if (len < 0.0001) return [0, 0]\n    return [x / len, y / len]\n}\n\nfunction setupBackground() {\n    // В Arcade нет прямого hex-цвета #0a0a0a без смены палитры,\n    // поэтому используем максимально тёмный базовый цвет.\n    let bg = image.create(screen.width, screen.height)\n    bg.fill(15) // чёрный\n\n    // Небольшие \"терминальные\" зелёные акценты\n    for (let x = 0; x < screen.width; x += 8) {\n        bg.setPixel(x, 4, 7)\n        bg.setPixel(x, screen.height - 5, 7)\n    }\n    for (let y = 0; y < screen.height; y += 8) {\n        bg.setPixel(4, y, 7)\n        bg.setPixel(screen.width - 5, y, 7)\n    }\n    scene.setBackgroundImage(bg)\n}\n\nfunction setupUI() {\n    hackBarBg = sprites.create(image.create(44, 8), SpriteKind.UI)\n    hackBarBg.setFlag(SpriteFlag.RelativeToCamera, true)\n    hackBarBg.setFlag(SpriteFlag.Ghost, true)\n    hackBarBg.setPosition(screen.width / 2, screen.height - 10)\n    hackBarBg.z = 90\n    hackBarBg.setFlag(SpriteFlag.Invisible, true)\n\n    hackBarFill = sprites.create(image.create(1, 4), SpriteKind.UI)\n    hackBarFill.setFlag(SpriteFlag.RelativeToCamera, true)\n    hackBarFill.setFlag(SpriteFlag.Ghost, true)\n    hackBarFill.z = 91\n    hackBarFill.setFlag(SpriteFlag.Invisible, true)\n\n    updateHackBar(0)\n}\n\nfunction updateHackBar(progress01: number) {\n    // Перерисовка рамки\n    let bg = image.create(44, 8)\n    bg.fill(1) // тёмный фон\n    bg.drawRect(0, 0, 44, 8, 7) // зелёная рамка\n    hackBarBg.setImage(bg)\n\n    // Полоса заполнения\n    let fillW = Math.max(1, Math.idiv(progress01 * 40, 1))\n    fillW = Math.min(40, fillW)\n    let fill = image.create(fillW, 4)\n    fill.fill(7)\n    hackBarFill.setImage(fill)\n\n    // Выравнивание fill по левому краю рамки\n    // Левая внутренняя граница рамки: centerX - 22 + 2 = centerX - 20\n    let leftInside = hackBarBg.x - 20\n    hackBarFill.left = leftInside\n    hackBarFill.y = hackBarBg.y\n}\n\nfunction setHackingState(active: boolean) {\n    isHacking = active\n    if (active) {\n        controller.moveSprite(player, 0, 0)\n        player.vx = 0\n        player.vy = 0\n        hackBarBg.setFlag(SpriteFlag.Invisible, false)\n        hackBarFill.setFlag(SpriteFlag.Invisible, false)\n        hackProgressMs = 0\n        updateHackBar(0)\n    } else {\n        controller.moveSprite(player, PLAYER_SPEED, PLAYER_SPEED)\n        hackBarBg.setFlag(SpriteFlag.Invisible, true)\n        hackBarFill.setFlag(SpriteFlag.Invisible, true)\n    }\n}\n\nfunction moveGuardPatrolStep() {\n    let tx = guardTargetA ? guardPatrolA.x : guardPatrolB.x\n    let ty = guardTargetA ? guardPatrolA.y : guardPatrolB.y\n\n    let dx = tx - guard.x\n    let dy = ty - guard.y\n    let n = normalize(dx, dy)\n    let nx = n[0]\n    let ny = n[1]\n\n    let step = GUARD_SPEED / 60\n    guard.x += nx * step\n    guard.y += ny * step\n\n    // Сохраняем \"куда смотрит\" охранник.\n    // Это важно для FOV, если он позже остановится на точке.\n    if (Math.abs(nx) > 0.001 || Math.abs(ny) > 0.001) {\n        guardFacingX = nx\n        guardFacingY = ny\n    }\n\n    if (distance(guard.x, guard.y, tx, ty) < 2) {\n        guardTargetA = !guardTargetA\n    }\n}\n\nfunction guardCanSeePlayer(): boolean {\n    // 1) Проверка дистанции\n    let toPX = player.x - guard.x\n    let toPY = player.y - guard.y\n    let d = Math.sqrt(toPX * toPX + toPY * toPY)\n    if (d > FOV_DISTANCE) return false\n    if (d < 0.0001) return true\n\n    // 2) Проверка угла (эквивалент конуса/треугольника FOV)\n    // dot = cos(theta) между направлением взгляда и направлением к игроку\n    let dirToPlayerX = toPX / d\n    let dirToPlayerY = toPY / d\n    let dot = guardFacingX * dirToPlayerX + guardFacingY * dirToPlayerY\n\n    // Если cos(theta) >= cos(half_fov), игрок внутри конуса зрения\n    return dot >= HALF_FOV_COS\n}\n\nfunction buildCRTOverlay() {\n    crtOverlay = sprites.create(image.create(screen.width, screen.height), SpriteKind.UI)\n    crtOverlay.setFlag(SpriteFlag.RelativeToCamera, true)\n    crtOverlay.setFlag(SpriteFlag.Ghost, true)\n    crtOverlay.z = 100\n    redrawCRT()\n}\n\nfunction redrawCRT() {\n    let img = image.create(screen.width, screen.height)\n    img.fill(0) // прозрачный\n\n    // Scanlines\n    for (let y = 0; y < screen.height; y += 2) {\n        img.drawLine(0, y, screen.width - 1, y, 1)\n    }\n\n    // Grain/noise\n    for (let i = 0; i < 45; i++) {\n        img.setPixel(randint(0, screen.width - 1), randint(0, screen.height - 1), 7)\n    }\n\n    crtOverlay.setImage(img)\n}\n\n// -------------------- Инициализация --------------------\nsetupBackground()\n\nplayer = sprites.create(img`\n    . . 7 7 7 7 . .\n    . 7 7 7 7 7 7 .\n    7 7 5 7 7 5 7 7\n    7 7 7 7 7 7 7 7\n    7 7 7 7 7 7 7 7\n    . 7 7 7 7 7 7 .\n    . . 7 7 7 7 . .\n    . . . 7 7 . . .\n`, SpriteKind.Player)\nplayer.setPosition(22, 60)\ncontroller.moveSprite(player, PLAYER_SPEED, PLAYER_SPEED)\nplayer.setStayInScreen(true)\n\n// Здесь можно загрузить реальный спрайт:\n// player.setImage(assets.image`elliot`)\n\nterminal = sprites.create(img`\n    7 7 7 7 7 7 7 7\n    7 1 1 1 1 1 1 7\n    7 1 7 7 7 7 1 7\n    7 1 7 1 1 7 1 7\n    7 1 7 7 7 7 1 7\n    7 1 1 1 1 1 1 7\n    7 7 7 7 7 7 7 7\n    . . 7 7 7 7 . .\n`, SpriteKind.Terminal)\nterminal.setPosition(84, 60)\n\n// Здесь можно загрузить реальный спрайт:\n// terminal.setImage(assets.image`terminal`)\n\nguard = sprites.create(img`\n    . 3 3 3 3 3 3 .\n    3 3 3 3 3 3 3 3\n    3 3 8 3 3 8 3 3\n    3 3 3 3 3 3 3 3\n    3 3 3 3 3 3 3 3\n    . 3 3 3 3 3 3 .\n    . . 3 3 3 3 . .\n    . . . 3 3 . . .\n`, SpriteKind.Guard)\nguard.setPosition(guardPatrolA.x, guardPatrolA.y)\n\n// Здесь можно загрузить реальный спрайт:\n// guard.setImage(assets.image`ecorpGuard`)\n\nsetupUI()\nbuildCRTOverlay()\n\n// -------------------- Управление --------------------\n// В Arcade стандартно движение на стрелках/геймпаде.\n// Кнопка A: начать хак, если рядом с терминалом.\ncontroller.A.onEvent(ControllerButtonEvent.Pressed, function () {\n    if (caught || terminalHacked || isHacking) return\n\n    if (distance(player.x, player.y, terminal.x, terminal.y) <= INTERACT_DISTANCE) {\n        setHackingState(true)\n    }\n})\n\n// -------------------- Апдейты --------------------\ngame.onUpdate(function () {\n    if (caught) return\n\n    if (!isHacking) {\n        moveGuardPatrolStep()\n    }\n\n    if (guardCanSeePlayer()) {\n        caught = true\n        game.over(false, effects.melt)\n    }\n})\n\ngame.onUpdateInterval(100, function () {\n    if (caught) return\n\n    if (isHacking) {\n        hackProgressMs += 100\n        let p = hackProgressMs / HACK_TIME_MS\n        if (p > 1) p = 1\n        updateHackBar(p)\n\n        if (hackProgressMs >= HACK_TIME_MS) {\n            terminalHacked = true\n            setHackingState(false)\n            terminal.image.fill(7) // визуально показываем \"взломано\"\n            game.splash(\"Hack complete\")\n        }\n    }\n})\n\ngame.onUpdateInterval(120, function () {\n    redrawCRT()\n})\n\n"}]},{"timestamp":1773954935683,"editorVersion":"4.0.12","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":84,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block></xml>"]]}]},{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":160,"diffs":[[1,""]]},{"start1":1,"length1":7524,"diffs":[[1,""]]}]},{"type":"edited","filename":"main.py","patch":[{"start1":0,"length1":125,"diffs":[[1,""]]},{"start1":1,"length1":105,"diffs":[[1,"let caught = false\n"]]},{"start1":21,"length1":118,"diffs":[[1,"// UI: прогресс-бар\nlet hackBarBg: Sprite = null\nlet hackBarFill: Sprite = null\n"]]},{"start1":102,"length1":100,"diffs":[[1,"// CRT overlay\nlet crtOverlay: Sprite = null\n"]]},{"start1":148,"length1":422,"diffs":[[1,"// -------------------- Вспомогательные функции --------------------\nfunction distance(x1: number, y1: number, x2: number, y2: number): number {\n    let dx = x2 - x1\n    let dy = y2 - y1\n"]]},{"start1":375,"length1":0,"diffs":[[1,"}\n"]]},{"start1":378,"length1":141,"diffs":[[1,"function normalize(x: number, y: number): number[] {\n    let len = Math.sqrt(x * x + y * y)\n    if (len < 0.0001) return [0, 0]\n    return [x / len, y / len]\n}\n"]]},{"start1":539,"length1":59,"diffs":[[1,"function setupBackground() {\n    // В Arcade нет прямого hex-цвета #0a0a0a без смены палитры,\n    // поэтому используем максимально тёмный базовый цвет.\n    let bg = image.create(screen.width, screen.height)\n    bg.fill(15) // чёрный\n"]]},{"start1":774,"length1":346,"diffs":[[1,"    // Небольшие \"терминальные\" зелёные акценты\n    for (let x = 0; x < screen.width; x += 8) {\n        bg.setPixel(x, 4, 7)\n        bg.setPixel(x, screen.height - 5, 7)\n    }\n    f