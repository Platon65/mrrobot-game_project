riteKind.create()\n}\n"]]},{"start1":161,"length1":0,"diffs":[[1,"//  ------------------ Config ------------------\nlet PLAYER_SPEED = 70\nlet GUARD_SPEED = 36\nlet INTERACT_DISTANCE = 18\nlet HACK_TIME_MS = 3000\nlet FOV_DISTANCE = 55\nlet FOV_ANGLE_DEG = 70\nlet HALF_FOV_COS = Math.cos(FOV_ANGLE_DEG / 2 * Math.PI / 180)\n//  ------------------ Globals ------------------\nlet hero = null\nlet ecorp_guard = null\nlet terminal_node = null\nlet hack_bar_bg = null\nlet hack_bar_fill = null\nlet crt_overlay = null\nlet border_overlay = null\nlet guard_patrol_a_x = 34\nlet guard_patrol_a_y = 28\nlet guard_patrol_b_x = 132\nlet guard_patrol_b_y = 92\nlet guard_target_a = false\nlet guard_facing_x = 1\nlet guard_facing_y = 0\nlet is_hacking = false\nlet hack_progress_ms = 0\nlet terminal_hacked = false\nlet caught = false\n//  ------------------ Helpers ------------------\nfunction dist(x1: number, y1: number, x2: number, y2: number): number {\n    let dx = x2 - x1\n    let dy = y2 - y1\n    return Math.sqrt(dx * dx + dy * dy)\n}\n\nfunction normalize(x: number, y: number): number[] {\n    let length = Math.sqrt(x * x + y * y)\n    if (length < 0.0001) {\n        return [0, 0]\n    }\n    \n    return [x / length, y / length]\n}\n\nfunction setup_background() {\n    scene.setBackgroundColor(15)\n    let border_img = image.create(screen.width, screen.height)\n    border_img.fill(0)\n    for (let x = 0; x < screen.width; x += 8) {\n        border_img.setPixel(x, 4, 7)\n        border_img.setPixel(x, screen.height - 5, 7)\n    }\n    for (let y = 0; y < screen.height; y += 8) {\n        border_img.setPixel(4, y, 7)\n        border_img.setPixel(screen.width - 5, y, 7)\n    }\n    \n    border_overlay = sprites.create(border_img, SpriteKind.UI)\n    border_overlay.setFlag(SpriteFlag.Ghost, true)\n    border_overlay.setFlag(SpriteFlag.RelativeToCamera, true)\n    border_overlay.z = 80\n}\n\nfunction setup_ui() {\n    \n    hack_bar_bg = sprites.create(image.create(50, 8), SpriteKind.UI)\n    hack_bar_bg.setFlag(SpriteFlag.Ghost, true)\n    hack_bar_bg.setFlag(SpriteFlag.RelativeToCamera, true)\n    hack_bar_bg.setFlag(SpriteFlag.Invisible, true)\n    hack_bar_bg.setPosition(screen.width / 2, screen.height - 10)\n    hack_bar_bg.z = 90\n    hack_bar_fill = sprites.create(image.create(1, 4), SpriteKind.UI)\n    hack_bar_fill.setFlag(SpriteFlag.Ghost, true)\n    hack_bar_fill.setFlag(SpriteFlag.RelativeToCamera, true)\n    hack_bar_fill.setFlag(SpriteFlag.Invisible, true)\n    hack_bar_fill.z = 91\n    update_hack_bar(0)\n}\n\nfunction update_hack_bar(progress01: number) {\n    let bg_image = image.create(50, 8)\n    bg_image.fill(1)\n    bg_image.drawRect(0, 0, 50, 8, 7)\n    hack_bar_bg.setImage(bg_image)\n    let fill_w = Math.round(progress01 * 46)\n    if (fill_w < 1) {\n        fill_w = 1\n    }\n    \n    if (fill_w > 46) {\n        fill_w = 46\n    }\n    \n    let fill_image = image.create(fill_w, 4)\n    fill_image.fill(7)\n    hack_bar_fill.setImage(fill_image)\n    hack_bar_fill.left = hack_bar_bg.left + 2\n    hack_bar_fill.y = hack_bar_bg.y\n}\n\nfunction set_hacking_state(active: boolean) {\n    \n    is_hacking = active\n    if (active) {\n        controller.moveSprite(hero, 0, 0)\n        hero.vx = 0\n        hero.vy = 0\n        hack_progress_ms = 0\n        update_hack_bar(0)\n        hack_bar_bg.setFlag(SpriteFlag.Invisible, false)\n        hack_bar_fill.setFlag(SpriteFlag.Invisible, false)\n    } else {\n        controller.moveSprite(hero, PLAYER_SPEED, PLAYER_SPEED)\n        hack_bar_bg.setFlag(SpriteFlag.Invisible, true)\n        hack_bar_fill.setFlag(SpriteFlag.Invisible, true)\n    }\n    \n}\n\nfunction move_guard_patrol() {\n    \n    let tx = guard_target_a ? guard_patrol_a_x : guard_patrol_b_x\n    let ty = guard_target_a ? guard_patrol_a_y : guard_patrol_b_y\n    let dx = tx - ecorp_guard.x\n    let dy = ty - ecorp_guard.y\n    let n = normalize(dx, dy)\n    let nx = n[0]\n    let ny = n[1]\n    let step = GUARD_SPEED / 60\n    ecorp_guard.x += nx * step\n    ecorp_guard.y += ny * step\n    if (Math.abs(nx) > 0.001 || Math.abs(ny) > 0.001) {\n        guard_facing_x = nx\n        guard_facing_y = ny\n    }\n    \n    if (dist(ecorp_guard.x, ecorp_guard.y, tx, ty) < 2) {\n        guard_target_a = !guard_target_a\n    }\n    \n}\n\nfunction guard_can_see_hero(): boolean {\n    let to_px = hero.x - ecorp_guard.x\n    let to_py = hero.y - ecorp_guard.y\n    let d = Math.sqrt(to_px * to_px + to_py * to_py)\n    if (d > FOV_DISTANCE) {\n        return false\n    }\n    \n    if (d < 0.0001) {\n        return true\n    }\n    \n    let dir_to_hero_x = to_px / d\n    let dir_to_hero_y = to_py / d\n    let dot = guard_facing_x * dir_to_hero_x + guard_facing_y * dir_to_hero_y\n    return dot >= HALF_FOV_COS\n}\n\nfunction redraw_crt() {\n    let overlay_image = image.create(screen.width, screen.height)\n    overlay_image.fill(0)\n    for (let y = 0; y < screen.height; y += 2) {\n        overlay_image.drawLine(0, y, screen.width - 1, y, 1)\n    }\n    for (let i = 0; i < 45; i++) {\n        overlay_image.setPixel(randint(0, screen.width - 1), randint(0, screen.height - 1), 7)\n    }\n    crt_overlay.setImage(overlay_image)\n}\n\n//  ------------------ Init ------------------\nsetup_background()\nhero = sprites.create(img`\n    . . 7 7 7 7 . .\n    . 7 7 7 7 7 7 .\n    7 7 5 7 7 5 7 7\n    7 7 7 7 7 7 7 7\n    7 7 7 7 7 7 7 7\n    . 7 7 7 7 7 7 .\n    . . 7 7 7 7 . .\n    . . . 7 7 . . .\n`, SpriteKind.Player)\nhero.setPosition(22, 60)\nhero.setStayInScreen(true)\ncontroller.moveSprite(hero, PLAYER_SPEED, PLAYER_SPEED)\nterminal_node = sprites.create(img`\n    7 7 7 7 7 7 7 7\n    7 1 1 1 1 1 1 7\n    7 1 7 7 7 7 1 7\n    7 1 7 1 1 7 1 7\n    7 1 7 7 7 7 1 7\n    7 1 1 1 1 1 1 7\n    7 7 7 7 7 7 7 7\n    . . 7 7 7 7 . .\n`, SpriteKind.Terminal)\nterminal_node.setPosition(84, 60)\necorp_guard = sprites.create(img`\n    . 3 3 3 3 3 3 .\n    3 3 3 3 3 3 3 3\n    3 3 8 3 3 8 3 3\n    3 3 3 3 3 3 3 3\n    3 3 3 3 3 3 3 3\n    . 3 3 3 3 3 3 .\n    . . 3 3 3 3 . .\n    . . . 3 3 . . .\n`, SpriteKind.Guard)\necorp_guard.setPosition(guard_patrol_a_x, guard_patrol_a_y)\nsetup_ui()\ncrt_overlay = sprites.create(image.create(screen.width, screen.height), SpriteKind.UI)\ncrt_overlay.setFlag(SpriteFlag.Ghost, true)\ncrt_overlay.setFlag(SpriteFlag.RelativeToCamera, true)\ncrt_overlay.z = 100\nredraw_crt()\n//  ------------------ Loop ------------------\ngame.onUpdate(function on_update() {\n    \n    if (caught) {\n        return\n    }\n    \n    if (!is_hacking) {\n        move_guard_patrol()\n    }\n    \n    if (!terminal_hacked && !is_hacking) {\n        if (dist(hero.x, hero.y, terminal_node.x, terminal_node.y) <= INTERACT_DISTANCE) {\n            set_hacking_state(true)\n        }\n        \n    }\n    \n    if (guard_can_see_hero()) {\n        caught = true\n        game.over(false, effects.melt)\n    }\n    \n})\ngame.onUpdateInterval(100, function on_update_hacking() {\n    let p: number;\n    \n    if (caught) {\n        return\n    }\n    \n    if (is_hacking) {\n        hack_progress_ms += 100\n        p = hack_progress_ms / HACK_TIME_MS\n        if (p > 1) {\n            p = 1\n        }\n        \n        update_hack_bar(p)\n        if (hack_progress_ms >= HACK_TIME_MS) {\n            terminal_hacked = true\n            terminal_node.setImage(img`\n                7 7 7 7 7 7 7 7\n                7 7 7 7 7 7 7 7\n                7 7 1 1 1 1 7 7\n                7 7 1 7 7 1 7 7\n                7 7 1 1 1 1 7 7\n                7 7 7 7 7 7 7 7\n                7 7 7 7 7 7 7 7\n                . . 7 7 7 7 . .\n            `)\n            set_hacking_state(false)\n            game.splash(\"Hack complete\")\n        }\n        \n    }\n    \n})\ngame.onUpdateInterval(120, function on_update_crt() {\n    redraw_crt()\n})\n"]]}]},{"type":"edited","filename":"main.py","patch":[{"start1":126,"length1":135,"diffs":[[1,"# ------------------ Config ----------